.env
.env.*
!.env.example
.venv/
.tools/
__pycache__/
*.pyc
*.pyo
.DS_Store
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/

# Generated dependency, cache, coverage, and build directories can also occur
# inside review prototypes. Keep the authored prototype source, never its local
# install or compiled output.
**/node_modules/
**/.npm-cache/
**/.vite/
**/dist/
**/coverage/
*.tsbuildinfo

# Frontend dependencies and build output.
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
frontend/coverage/
# Mirrored from `python tools/build_dashboard.py emit-frontend-manifest`;
# regenerated by the Python pipeline on every dashboard build.
frontend/public/manifest.json
frontend/public/browse/
frontend/public/judge-demo.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local image-generation and visual QA scratch output. Curated assets and QA
# captures live in their named docs/frontend directories instead.
/tmp/

# Reports are runtime artifacts (raw_runs.jsonl + CSVs + .md). Keep the
# directory but ignore everything under it so local runs never leak
# into commits.
reports/**
!reports/.gitkeep

# Editor workspace files.
*.code-workspace
