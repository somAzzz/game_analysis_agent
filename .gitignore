.env
.env.*
!.env.example
.venv/
__pycache__/
*.pyc
*.pyo
.DS_Store
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/

# Frontend dependencies and build output.
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.vite/
frontend/coverage/
# Mirrored from `python tools/build_dashboard.py emit-frontend-manifest`;
# regenerated by the Python pipeline on every dashboard build.
frontend/public/manifest.json
frontend/public/browse/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Reports are runtime artifacts (raw_runs.jsonl + CSVs + .md). Keep the
# directory but ignore everything under it so local runs never leak
# into commits.
reports/**
!reports/.gitkeep
