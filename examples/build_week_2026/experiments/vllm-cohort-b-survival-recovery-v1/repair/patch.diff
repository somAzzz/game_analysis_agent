+func _validate_crisis_recovery_action(errors: Array[String]) -> void:
+	var registry: Node = root.get_node("/root/DataRegistry")
+	var action = registry.get_action_by_id("rent_talk_extension")
+	if action == null:
+		errors.append("rent_talk_extension should exist for crisis recovery validation")
+		return
+	if int(action.effects.get("arrears_amount", 0)) >= 0:
+		errors.append("rent_talk_extension should reduce arrears")
+	if int(action.effects.get("stress", 0)) > 0:
+		errors.append("rent_talk_extension should create stress headroom")
+
 func _validate_monthly_rent(game_state: Node, errors: Array[String]) -> void:
