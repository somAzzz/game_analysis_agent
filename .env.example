# vLLM OpenAI-compatible endpoint.
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=local-dev-token

# Set this to the exact Hugging Face repo id or local model path you have.
# Examples:
# MODEL_ID=/models/qwen3.6-35b-a3b-nvfp4
# MODEL_ID=Qwen/Qwen3.6-35B-A3B-NVFP4
MODEL_ID=/models/qwen3.6-nvfp4

# Agent generation defaults.
AGENT_TEMPERATURE=0.2
AGENT_MAX_TOKENS=4096

# Godot CLI defaults used by docs/scripts.
GODOT_BIN=godot4
GODOT_PROJECT_PATH=/Users/bo/projects/study-in-germany
