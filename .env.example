# =============================================================================
# game_analysis_agent environment configuration
# =============================================================================
# Copy this file to .env before running anything. The placeholders are
# intentional so the demo works out of the box.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM provider selection
# -----------------------------------------------------------------------------
# Options: vllm (local GPU) | sglang (local GPU alt) | deepseek (cloud)
LLM_PROVIDER=vllm

# -----------------------------------------------------------------------------
# Local vLLM (default local backend)
# -----------------------------------------------------------------------------
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=local-dev-token
# Checkpoint loaded by the vLLM server and the stable model id exposed by its
# OpenAI-compatible API. The Python client and Compose share the served name.
LLM_MODEL=nvidia/Qwen3.6-27B-NVFP4
LLM_SERVED_MODEL_NAME=qwen3.6-27b-nvfp4

# -----------------------------------------------------------------------------
# Local SGLang (alternative)
# -----------------------------------------------------------------------------
SGLANG_BASE_URL=http://localhost:30000/v1
SGLANG_API_KEY=dummy
SGLANG_MODEL=Qwen/Qwen3.6-35B-A3B

# -----------------------------------------------------------------------------
# DeepSeek (cloud fallback, OpenAI-compatible)
# -----------------------------------------------------------------------------
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=REPLACE_ME

# Agent generation defaults.
AGENT_TEMPERATURE=0.2
AGENT_MAX_TOKENS=4096

# Interactive player tool loop
TOOL_MAX_ROUNDS=8

# -----------------------------------------------------------------------------
# Godot CLI defaults
# -----------------------------------------------------------------------------
# Use the compose-aware wrapper by default; set `godot4` for a native install.
GODOT_BIN=scripts/godot-docker-wrapper
# Container fallback/sidecar used by scripts/godot-docker-wrapper.
GODOT_DOCKER_IMAGE=barichello/godot-ci:4.4
# Shared parent of game_analysis_agent and study-in-germany. The sidecar mounts
# it at the identical absolute path so both game input and Agent output work.
# Required for any Godot-driven subcommand; uncomment and edit before running.
# GODOT_DOCKER_MOUNT_ROOT=/abs/path/to/shared/parent
# Path to the game project being analyzed (e.g. study-in-germany). Required
# by the new probe / export / interactive tools. Uncomment and edit before
# running anything that touches the game checkout.
# GAME_PROJECT_PATH=/abs/path/to/study-in-germany

# Default Monte Carlo settings
SIM_RUNS=100
SIM_POLICY=balanced
SIM_WEEKS=20
SIM_SEED=42
SIM_DIFFICULTY=normal

# -----------------------------------------------------------------------------
# Docker / vLLM container knobs (used by docker-compose.yml)
# -----------------------------------------------------------------------------
# Hugging Face token — required if your model lives behind an auth gate.
HF_TOKEN=

# Host port the vLLM container binds to. Pinned to 8000 to match the
# VLLM_BASE_URL default above. Bump if you already use 8000 elsewhere.
VLLM_BIND_PORT=8000

# Maximum context length the served model accepts. Default 32k is the
# safe baseline for Qwen3.6 27B NVFP4 with MTP enabled.
LLM_MAX_MODEL_LEN=32768

# MTP speculative decoding. Set to 0 if your checkpoint lacks MTP
# weights (the --speculative-config flag otherwise errors out).
LLM_ENABLE_MTP=1

# Which GPU the vLLM container should use. Use ``all`` to bind every
# visible device, or set to the index of a single card.
CUDA_VISIBLE_DEVICES=0

# Speed up model downloads from HF Hub via the hf-transfer plugin.
# Optional; set to 1 only if you have the ``hf_transfer`` plugin
# installed in the vLLM container (the default image does).
HF_HUB_ENABLE_HF_TRANSFER=0
