#!/usr/bin/env bash
set -euo pipefail

# Keep host paths unchanged inside the container so --path/--out arguments
# generated by the Python runner remain valid. Override either value when the
# checkout layout or cached image differs.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PROJECTS_ROOT="${GODOT_DOCKER_MOUNT_ROOT:-$(cd "$SCRIPT_DIR/../.." && pwd)}"
IMAGE="${GODOT_DOCKER_IMAGE:-barichello/godot-ci:4.4}"
CONTAINER_HOME="${GODOT_DOCKER_HOME:-/tmp/game-analysis-godot-home}"
COMPOSE_SERVICE="${GODOT_COMPOSE_SERVICE:-godot}"

mkdir -p "$CONTAINER_HOME"

running_id="$(
  docker compose \
    --project-directory "$REPO_ROOT" \
    --file "$REPO_ROOT/docker-compose.yml" \
    ps --quiet --status running "$COMPOSE_SERVICE" 2>/dev/null || true
)"
if [[ -n "$running_id" ]]; then
  exec docker compose \
    --project-directory "$REPO_ROOT" \
    --file "$REPO_ROOT/docker-compose.yml" \
    exec --no-TTY \
    --user "$(id -u):$(id -g)" \
    --env "HOME=$CONTAINER_HOME" \
    "$COMPOSE_SERVICE" godot "$@"
fi

exec docker run --rm \
  --user "$(id -u):$(id -g)" \
  --env "HOME=$CONTAINER_HOME" \
  --volume "$PROJECTS_ROOT:$PROJECTS_ROOT" \
  --volume /tmp:/tmp \
  --workdir "$PWD" \
  "$IMAGE" godot "$@"
