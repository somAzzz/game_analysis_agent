#!/bin/sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
OUTPUT=${P4_LINUX_AMD64_OUTPUT:-$ROOT/reports/platform-ci-local/linux-amd64}
EVIDENCE=${P4_LINUX_AMD64_EVIDENCE:-$OUTPUT/evidence.json}
IMAGE=${P4_LINUX_AMD64_IMAGE:-playtest-forge-judge:p4-linux-amd64}

test "$(uname -s)-$(uname -m)" = "Linux-x86_64" || {
  echo "run-p4-linux-amd64 requires a native Linux x86_64 host" >&2
  exit 2
}
command -v docker >/dev/null 2>&1 || {
  echo "Docker Engine is required" >&2
  exit 2
}
docker info >/dev/null
test -z "$(git -C "$ROOT" status --porcelain --untracked-files=all)" || {
  echo "platform acceptance requires a clean worktree" >&2
  exit 2
}

mkdir -p "$OUTPUT"
cd "$ROOT"
scripts/setup-evaluator
EVALUATOR_OFFLINE=1 scripts/setup-evaluator
python3 tools/judge_doctor.py --mode inspect --json > "$OUTPUT/doctor-inspect.json"
uv run python tools/judge_doctor.py --mode replay --json > "$OUTPUT/doctor-replay.json"
uv run python tools/judge_doctor.py --mode dashboard-native --json > "$OUTPUT/doctor-dashboard-native.json"
./judge --mode inspect --offline --json --output-dir - > "$OUTPUT/judge-inspect.json"
./judge --mode replay --offline --json --output-dir - > "$OUTPUT/judge-replay.json"

docker build --tag "$IMAGE" --file Dockerfile.judge .
docker image inspect "$IMAGE" --format '{{json .}}' > "$OUTPUT/docker-image.json"
docker run --rm --network none --read-only --tmpfs /tmp:size=32m \
  --cap-drop ALL --security-opt no-new-privileges "$IMAGE" \
  --mode inspect --offline --json --output-dir - > "$OUTPUT/container-inspect.json"
docker run --rm --network none --read-only --tmpfs /tmp:size=32m \
  --cap-drop ALL --security-opt no-new-privileges "$IMAGE" \
  --mode replay --offline --json --output-dir - > "$OUTPUT/container-replay.json"

name=playtest-forge-p4-amd64
cleanup() { docker rm --force "$name" >/dev/null 2>&1 || true; }
trap cleanup EXIT INT TERM
docker run --detach --name "$name" --publish 127.0.0.1:18080:8080 \
  --read-only --tmpfs /tmp:size=16m --cap-drop ALL --security-opt no-new-privileges \
  --entrypoint /app/.venv/bin/python "$IMAGE" \
  tools/run_judge_api.py --host 0.0.0.0 --port 8080 --frontend /app/frontend/dist >/dev/null
for attempt in $(seq 1 20); do
  if curl --fail --silent http://127.0.0.1:18080/api/provider-status > "$OUTPUT/provider-status.json"; then
    break
  fi
  sleep 1
done
curl --fail --silent http://127.0.0.1:18080/ | grep -q '<div id="root"></div>'
cleanup
trap - EXIT INT TERM

uv run python tools/record_platform_evidence.py \
  --mode linux-amd64 --artifact-dir "$OUTPUT" --output "$EVIDENCE"
echo "Linux amd64 P4 evidence: $EVIDENCE"
