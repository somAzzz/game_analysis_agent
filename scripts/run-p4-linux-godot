#!/bin/sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
OUTPUT=${P4_LINUX_GODOT_OUTPUT:-$ROOT/reports/platform-godot}
EVIDENCE=${P4_LINUX_GODOT_EVIDENCE:-$OUTPUT/evidence.json}

test "$(uname -s)-$(uname -m)" = "Linux-x86_64" || {
  echo "run-p4-linux-godot requires a native Linux x86_64 host" >&2
  exit 2
}
test -z "$(git -C "$ROOT" status --porcelain --untracked-files=all)" || {
  echo "platform acceptance requires a clean worktree" >&2
  exit 2
}

cd "$ROOT"
scripts/setup-build-week-toolchain --json
. .tools/build-week/env.sh
export GAME_PROJECT_PATH="$OUTPUT/game-runtime"
uv run python tools/prepare_embedded_demo.py \
  --output "$GAME_PROJECT_PATH" --replace --json > "$OUTPUT/embedded-demo.json"
uv run python tools/judge_doctor.py --mode real-game --json > "$OUTPUT/doctor-real-game.json"
uv run python tools/run_gameplay_agent.py sim \
  --run-id ci-smoke --runs 12 --policy balanced --difficulty normal --seed 4242 \
  --scenario default_first_semester --weeks 20 --report-dir "$OUTPUT/ci-smoke"
uv run python tools/record_platform_evidence.py \
  --mode linux-godot --artifact-dir "$OUTPUT" --output "$EVIDENCE"
echo "Linux Godot P4 evidence: $EVIDENCE"
