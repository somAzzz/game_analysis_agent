#!/bin/sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
: "${OPENAI_API_KEY:?set OPENAI_API_KEY in the server environment}"
OUTPUT=${P4_LIVE_OPENAI_OUTPUT:-$ROOT/reports/platform-live-openai}
EVIDENCE=${P4_LIVE_OPENAI_EVIDENCE:-$OUTPUT/evidence.json}
PORT=${P4_LIVE_OPENAI_PORT:-18082}

test -z "$(git -C "$ROOT" status --porcelain --untracked-files=all)" || {
  echo "live acceptance requires a clean worktree" >&2
  exit 2
}
mkdir -p "$OUTPUT"
cd "$ROOT"
if [ -z "${GAME_PROJECT_PATH:-}" ]; then
  GAME_PROJECT_PATH="$OUTPUT/game-runtime"
  uv run python tools/prepare_embedded_demo.py \
    --output "$GAME_PROJECT_PATH" --replace --json > "$OUTPUT/embedded-demo.json"
fi
export GAME_PROJECT_PATH
uv run python tools/judge_doctor.py --mode live-openai --json > "$OUTPUT/doctor-live-openai.json"
uv run python tools/run_judge_api.py --host 127.0.0.1 --port "$PORT" \
  --enable-live-openai > "$OUTPUT/api.stdout" 2> "$OUTPUT/api.stderr" &
pid=$!
cleanup() { kill "$pid" >/dev/null 2>&1 || true; wait "$pid" 2>/dev/null || true; }
trap cleanup EXIT INT TERM
for attempt in $(seq 1 30); do
  if curl --fail --silent "http://127.0.0.1:$PORT/api/provider-status" > "$OUTPUT/provider-status.json"; then
    break
  fi
  sleep 1
done
jq -e '.providers.openai.live_campaign_ready == true' "$OUTPUT/provider-status.json" >/dev/null
curl --fail --silent -X POST "http://127.0.0.1:$PORT/api/campaigns" \
  -H 'Content-Type: application/json' \
  --data '{"provider":"openai","personas":["newbie"],"seeds":[42],"max_weeks":2}' \
  > "$OUTPUT/live-openai-created.json"
campaign_id=$(jq -r '.campaign_id' "$OUTPUT/live-openai-created.json")
test -n "$campaign_id" && test "$campaign_id" != null
for attempt in $(seq 1 180); do
  curl --fail --silent "http://127.0.0.1:$PORT/api/campaigns/$campaign_id" \
    > "$OUTPUT/live-openai-campaign.json"
  status=$(jq -r '.status' "$OUTPUT/live-openai-campaign.json")
  case "$status" in
    completed) break ;;
    failed|cancelled) jq . "$OUTPUT/live-openai-campaign.json" >&2; exit 1 ;;
  esac
  sleep 1
done
jq -e '.status == "completed" and .mode == "live" and .result.provider == "openai"' \
  "$OUTPUT/live-openai-campaign.json" >/dev/null
cleanup
trap - EXIT INT TERM

uv run python tools/record_platform_evidence.py \
  --mode live-openai --artifact-dir "$OUTPUT" --output "$EVIDENCE"
echo "Live OpenAI P4 evidence: $EVIDENCE"
