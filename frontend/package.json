{
  "name": "game-analysis-agent-frontend",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "description": "React + React Flow dashboard for game_analysis_agent reports.",
  "scripts": {
    "dev": "vite",
    "prepare:public": "mkdir -p public && rm -rf public/manifest.json public/browse public/judge-demo.json && cp -R public-demo/manifest.json public-demo/browse public-demo/judge-demo.json public/",
    "build:public": "npm run prepare:public && VITE_BASE_PATH=/game_analysis_agent/ npm run build",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@xyflow/react": "^12.3.0",
    "dagre": "^0.8.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dagre": "^0.7.52",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.6",
    "jsdom": "^25.0.1",
    "typescript": "^5.5.4",
    "vite": "^8.1.5",
    "vitest": "^3.2.6"
  }
}
